bash
# .env.example
# Copy this file to .env and fill with your production values

# Database
POSTGRES_DB=household_store
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-to-strong-password

# App
SERVER_PORT=8443

# SSL
SSL_KEYSTORE_PASSWORD=change-this-to-strong-password
SSL_KEY_ALIAS=tomcat
SSL_KEYSTORE_PATH=./keystore.p12

# JWT
JWT_SECRET=change-this-to-strong-secret-min-32-chars-long