# .env.example
# Copy this file to .env and replace placeholder values with real secrets

# =========================================================================
# DATABASE
# =========================================================================
POSTGRES_DB=household_store
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-database-password-here

# =========================================================================
# APPLICATION
# =========================================================================
SERVER_PORT=8443

# =========================================================================
# SSL
# =========================================================================
SSL_KEYSTORE_PASSWORD=your-strong-keystore-password-here
SSL_KEY_ALIAS=tomcat
SSL_KEYSTORE_PATH=./keystore.p12

# =========================================================================
# JWT
# =========================================================================
JWT_SECRET=your-strong-jwt-secret-min-32-chars-long-here-1234567890

# =========================================================================
# DEFAULT ADMIN USER (created on first startup)
# =========================================================================
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=your-strong-admin-password-here
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator

# =========================================================================
# RATE LIMITING (optional, defaults are 10 requests per minute)
# =========================================================================
# app.rate-limiting.enabled=true
# app.rate-limiting.capacity=10
# app.rate-limiting.refill-period-minutes=1