<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260414-add-payment-status-to-sales-orders" author="GALThor">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="sales_orders" columnName="payment_status"/>
            </not>
        </preConditions>

        <comment>Add payment_status column to sales_orders table if not exists</comment>

        <addColumn tableName="sales_orders">
            <column name="payment_status" type="VARCHAR(50)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="sales_orders" columnName="payment_status"/>
        </rollback>
    </changeSet>

</databaseChangeLog>