        </createIndex>

        <createIndex tableName="payment_transactions" schemaName="household_schema" indexName="idx_payment_transactions_deleted">
            <column name="deleted"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="invoices" schemaName="household_schema" indexName="idx_invoices_deleted"/>
            <dropIndex tableName="sales_orders" schemaName="household_schema" indexName="idx_sales_orders_deleted"/>
            <dropIndex tableName="purchase_orders" schemaName="household_schema" indexName="idx_purchase_orders_deleted"/>
            <dropIndex tableName="payment_transactions" schemaName="household_schema" indexName="idx_payment_transactions_deleted"/>
        </rollback>
    </changeSet>

</databaseChangeLog>