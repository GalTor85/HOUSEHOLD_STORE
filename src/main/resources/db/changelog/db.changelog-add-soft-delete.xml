<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- =========================================================================
         SOFT DELETE COLUMNS FOR ALL ENTITIES
         Author: G@LTor85
         Date: 2026-04-19
         Description: Add soft delete columns to support logical deletion
    ========================================================================= -->

    <!-- INVOICES -->
    <changeSet id="add-soft-delete-to-invoices" author="G@LTor85">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="invoices" schemaName="household_schema"/>
        </preConditions>

        <comment>Add soft delete columns to invoices table</comment>

        <addColumn tableName="invoices" schemaName="household_schema">
            <column name="deleted" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="invoices" schemaName="household_schema">
            <column name="deleted_at" type="timestamp"/>
        </addColumn>

        <addColumn tableName="invoices" schemaName="household_schema">
            <column name="deleted_by" type="bigint"/>
        </addColumn>

        <addColumn tableName="invoices" schemaName="household_schema">
            <column name="delete_reason" type="varchar(500)"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="invoices" schemaName="household_schema" columnName="deleted"/>
            <dropColumn tableName="invoices" schemaName="household_schema" columnName="deleted_at"/>
            <dropColumn tableName="invoices" schemaName="household_schema" columnName="deleted_by"/>
            <dropColumn tableName="invoices" schemaName="household_schema" columnName="delete_reason"/>
        </rollback>
    </changeSet>

