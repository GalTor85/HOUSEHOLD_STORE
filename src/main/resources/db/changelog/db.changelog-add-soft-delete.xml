    <!-- OPTIONAL: Add indexes for better query performance -->
    <changeSet id="add-soft-delete-indexes" author="G@LTor85">
        <comment>Add indexes on deleted flag for soft delete queries</comment>

        <createIndex tableName="invoices" schemaName="household_schema" indexName="idx_invoices_deleted">
            <column name="deleted"/>
        </createIndex>

        <createIndex tableName="sales_orders" schemaName="household_schema" indexName="idx_sales_orders_deleted">
            <column name="deleted"/>
        </createIndex>

        <createIndex tableName="purchase_orders" schemaName="household_schema" indexName="idx_purchase_orders_deleted">
