<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">


    <!-- 1. Create tables -->
    <changeSet id="1" author="household" context="!test">
        <sqlFile path="01-initial-schema.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- 2. Default data - -->
    <changeSet id="2" author="household" context="!test">
        <sqlFile path="02-default-data.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- 3. Performance indexes -->
    <changeSet id="3" author="household">
        <sqlFile path="db/changelog/03-indexes.sql"
                 relativeToChangelogFile="false"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- 4. Payment method user types table -->
    <changeSet id="4" author="household">
        <sqlFile path="db/changelog/04-payment-method-user-types.sql"
                 relativeToChangelogFile="false"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- 5. Payment method user types constraints -->
    <changeSet id="5" author="household">
        <sqlFile path="db/changelog/05-payment-method-user-types-constraints.sql"
                 relativeToChangelogFile="false"
                 splitStatements="false"
                 stripComments="true"/>
    </changeSet>

    <!-- 6. Payment method user types trigger -->
    <changeSet id="6" author="household">
        <sqlFile path="db/changelog/06-payment-method-user-types-trigger.sql"
                 relativeToChangelogFile="false"
                 splitStatements="false"/>
    </changeSet>

    <include file="db/changelog/db.changelog-add-masked-identifier.xml"/>

    <include file="db/changelog/db.changelog-reservation.xml"/>

    <include file="db/changelog/db.changelog-warehouse-visibility.xml"/>

    <changeSet id="add-created-by-to-payment-transactions" author="system">
        <addColumn tableName="payment_transactions" schemaName="household_schema">
            <column name="created_by" type="bigint">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <include file="db/changelog/xxx-add-payment-status-to-sales-orders.xml"/>

    <include file="db/changelog/xxx-add-payment-status-to-purchase-orders.xml"/>

    <include file="db/changelog/remove-unused-bank-transactions.xml"/>

    <changeSet id="remove-purchase-order-type-enum" author="G@LTor85">
        <comment>Remove unused purchase_order_type enum</comment>
        <sql splitStatements="false">
            DO $$
            BEGIN
            IF EXISTS (SELECT 1 FROM pg_type WHERE typname = 'purchase_order_type') THEN
            DROP TYPE household_schema.purchase_order_type CASCADE;
            END IF;
            END $$;
        </sql>
    </changeSet>

    <include file="db/changelog/remove-product-price-rules.xml"/>

    <include file="db/changelog/remove-supplier-ratings.xml"/>

    <!-- NEW: Remove unused JPA relations (marker only, no DDL) -->
    <include file="db/changelog/db.changelog-remove-unused-relations.xml"/>

    <include file="db/changelog/db.changelog-remove-quantity-in-stock.xml"/>

    <!-- Soft delete columns for all entities -->
    <include file="db/changelog/db.changelog-add-soft-delete.xml"/>
</databaseChangeLog>