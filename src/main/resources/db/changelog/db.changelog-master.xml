<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Create schema -->
    <changeSet id="0" author="household">
        <sql>
            CREATE SCHEMA IF NOT EXISTS household_schema;
        </sql>
    </changeSet>

    <!-- 1. Create tables -->
    <changeSet id="1" author="household">
        <sqlFile path="db/changelog/01-initial-schema.sql"
                 relativeToChangelogFile="false"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- 2. Default data -->
    <changeSet id="2" author="household">
        <sqlFile path="db/changelog/02-default-data.sql"
                 relativeToChangelogFile="false"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- 3. Performance indexes -->
    <changeSet id="3" author="household">
        <sqlFile path="db/changelog/03-indexes.sql"
                 relativeToChangelogFile="false"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- 4. Payment method user types table -->
    <changeSet id="4" author="household">
        <sqlFile path="db/changelog/04-payment-method-user-types.sql"
                 relativeToChangelogFile="false"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- 5. Payment method user types constraints -->
    <changeSet id="5" author="household">
        <sqlFile path="db/changelog/05-payment-method-user-types-constraints.sql"
                 relativeToChangelogFile="false"
                 splitStatements="false"
                 stripComments="true"/>
    </changeSet>

    <!-- 6. Payment method user types trigger -->
    <changeSet id="6" author="household">
        <sqlFile path="db/changelog/06-payment-method-user-types-trigger.sql"
                 relativeToChangelogFile="false"
                 splitStatements="false"/>
    </changeSet>

    <include file="db/changelog/db.changelog-add-masked-identifier.xml"/>

    <include file="db/changelog/db.changelog-reservation.xml"/>

    <include file="db/changelog/db.changelog-warehouse-visibility.xml"/>

    <changeSet id="add-created-by-to-payment-transactions" author="system">
        <addColumn tableName="payment_transactions" schemaName="household_schema">
            <column name="created_by" type="bigint">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>